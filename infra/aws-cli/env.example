export AWS_REGION="us-east-1"
export PROJECT_NAME="market-copilot"
export ENVIRONMENT="staging"

# Existing network inputs
export VPC_ID="vpc-xxxxxxxx"
export SUBNET_ID="subnet-xxxxxxxx"
export AMI_ID="ami-xxxxxxxx"
export KEY_NAME="market-copilot-operators"

# Operator access
export SSH_CIDR="203.0.113.10/32"

# EC2 sizing
export INSTANCE_TYPE="t3.medium"

# Naming
export NAME_PREFIX="${PROJECT_NAME}-${ENVIRONMENT}"

# Resource names
export ARTIFACT_BUCKET="${NAME_PREFIX}-artifacts"
export IAM_ROLE_NAME="${NAME_PREFIX}-ec2-role"
export INSTANCE_PROFILE_NAME="${NAME_PREFIX}-instance-profile"
export SECURITY_GROUP_NAME="${NAME_PREFIX}-sg"
export EC2_NAME="${NAME_PREFIX}-app"
