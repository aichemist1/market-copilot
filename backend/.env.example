MARKET_COPILOT_DATABASE_URL=postgresql+psycopg://dev@localhost:5432/market_copilot
MARKET_COPILOT_ENVIRONMENT=development
MARKET_COPILOT_LOG_LEVEL=INFO

# Normalization provider options: stub | openai
MARKET_COPILOT_NORMALIZATION_PROVIDER=stub

# Set these when using the OpenAI-backed normalization adapter.
MARKET_COPILOT_OPENAI_API_KEY=
MARKET_COPILOT_OPENAI_MODEL=gpt-4.1-mini

# Artifact storage options: local | s3
MARKET_COPILOT_ARTIFACT_STORAGE_MODE=local
MARKET_COPILOT_LOCAL_ARTIFACT_ROOT=/Users/dev/Documents/market-copilot/.artifacts
MARKET_COPILOT_S3_BUCKET=
MARKET_COPILOT_S3_REGION=

# House XML source URL for scheduled ingestion.
MARKET_COPILOT_HOUSE_XML_SOURCE_URL=https://disclosures-clerk.house.gov/public_disc/financial-pdfs/2026FD.xml
